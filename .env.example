# ============================================
# DUDE AI - Environment Variables Template
# ============================================

# ── REQUIRED ────────────────────────────────

# Database Connection
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Session Secret (generate random string)
SESSION_SECRET=your-super-secret-random-string-here

# AI API - Groq (Required for chat)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Server Configuration
PORT=3000
NODE_ENV=development


# ── OPTIONAL ────────────────────────────────

# Google OAuth (for social login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback


# ── FUTURE FEATURES (Not Yet Implemented) ───

# Image Generation - Choose ONE:
# --------------------------------

# Option 1: OpenAI DALL-E
# Get key: https://platform.openai.com/api-keys
# Cost: ~$0.02 per image
# OPENAI_API_KEY=sk-...

# Option 2: Stability AI
# Get key: https://platform.stability.ai/
# Cost: ~$0.002 per image
# STABILITY_API_KEY=...

# Option 3: Replicate
# Get key: https://replicate.com/account/api-tokens
# Cost: Pay per use
# REPLICATE_API_TOKEN=...


# Web Search Integration - Choose ONE:
# -------------------------------------

# Option 1: SerpAPI (Recommended)
# Get key: https://serpapi.com/
# Free tier: 100 searches/month
# SERPAPI_KEY=...

# Option 2: Brave Search API
# Get key: https://brave.com/search/api/
# Free tier: 2,000 queries/month
# BRAVE_SEARCH_KEY=...

# Option 3: Google Custom Search
# Get key: https://developers.google.com/custom-search
# Free tier: 100 queries/day
# GOOGLE_SEARCH_KEY=...
# GOOGLE_SEARCH_CX=...


# ── NOTES ───────────────────────────────────
# 
# 1. Copy this file to .env and fill in your values
# 2. Never commit .env to version control
# 3. All features work without optional API keys
# 4. Add image/search keys when ready to use those features
# 
# ============================================
